# ============================================================
# apps/web — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================

# ── Server-side only (never exposed to the browser) ─────────

# Base URL of the Kaira DIT API (required)
API_URL=https://api.example.com

# API authentication key (required)
X_API_KEY=your-api-key-here

# API application/client ID (required)
X_API_ID=your-api-id-here

# ── Demo configuration — all required, available on server and client ──
# These are NEXT_PUBLIC_ so the client-side chat engine can read them directly.
# The values below are the canonical dev defaults.

NEXT_PUBLIC_DEMO_SESSION_ID=a6008af9-49de-4a90-8968-821c78a5bdc7
NEXT_PUBLIC_DEMO_SENDER_ID=4716721f-de0b-4faf-9df4-93c3be70292e
NEXT_PUBLIC_DEMO_CHATBOT_NICKNAME=haewon_live_v1
NEXT_PUBLIC_DEMO_CHATROOM_ID=eb35de17-4776-448f-8a65-5f9a20ae88c2
