{
  "name": "kaira-chat-sdk",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:docs": "turbo run dev --filter=docs",
    "start:web": "turbo run start --filter=web",
    "start:docs": "turbo run start --filter=docs",
    "docs:status:sync": "node ./scripts/render-feature-status.mjs sync",
    "docs:status:check": "node ./scripts/render-feature-status.mjs check",
    "deps:check": "pnpm exec syncpack lint",
    "deps:fix": "pnpm exec syncpack fix",
    "deps:outdated": "node ./scripts/run-syncpack-upgrade.mjs --check",
    "deps:upgrade": "node ./scripts/run-syncpack-upgrade.mjs",
    "lint": "turbo run lint",
    "clean": "turbo run clean --filter=./apps/* --filter=./packages/* && node -e \"require('fs').rmSync('.turbo', { recursive: true, force: true })\"",
    "clean:deps": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" exec node -e \"require('fs').rmSync('node_modules', { recursive: true, force: true })\" && node -e \"require('fs').rmSync('node_modules', { recursive: true, force: true })\"",
    "clean:all": "pnpm run clean && pnpm run clean:deps",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "test": "pnpm test:scripts && turbo run test",
    "test:scripts": "node ./packages/chat-core/node_modules/vitest/vitest.mjs run scripts/run-syncpack-upgrade.test.mjs",
    "validate": "pnpm deps:check && pnpm docs:status:check && pnpm lint && pnpm check-types && pnpm build && pnpm test",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "eslint": "^9.39.4",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "syncpack": "^14.3.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "type-fest": "^5.6.0",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm validate"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,html,yml,yaml}": "prettier --write"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.5",
      "react-dom": "^19.2.5"
    }
  }
}
