{
  "name": "kaira-chat-sdk",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:docs": "turbo run dev --filter=docs",
    "lint": "turbo run lint",
    "clean": "turbo run clean --filter=./apps/* --filter=./packages/* && node -e \"require('fs').rmSync('.turbo', { recursive: true, force: true })\"",
    "clean:deps": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" exec node -e \"require('fs').rmSync('node_modules', { recursive: true, force: true })\" && node -e \"require('fs').rmSync('node_modules', { recursive: true, force: true })\"",
    "clean:all": "pnpm run clean && pnpm run clean:deps",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "test": "turbo run test --if-present",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "eslint": "^9.39.4",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "turbo": "^2.8.17",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,html,yml,yaml}": "prettier --write"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
