{
  "name": "@kaira/chat-storage-indexeddb",
  "version": "0.1.0",
  "description": "IndexedDB storage adapter for Kaira Chat SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kaira/chat-core.git",
    "directory": "packages/chat-storage-indexeddb"
  },
  "license": "MIT",
  "scripts": {
    "prepack": "pnpm build",
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "check-types": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@kaira/chat-core": "workspace:*",
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat",
    "chat-sdk",
    "indexeddb",
    "storage",
    "browser",
    "persistence"
  ]
}
