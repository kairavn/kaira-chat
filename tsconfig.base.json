{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@kaira/chat-core": ["packages/chat-core/src/index.ts"],
      "@kaira/chat-react": ["packages/chat-react/src/index.ts"],
      "@kaira/chat-ui": ["packages/chat-ui/src/index.ts"],
      "@kaira/chat-devtools": ["packages/chat-devtools/src/index.ts"],
      "@kaira/chat-transport-polling": ["packages/chat-transport-polling/src/index.ts"],
      "@kaira/chat-provider-dit": ["packages/chat-provider-dit/src/index.ts"]
    }
  }
}
